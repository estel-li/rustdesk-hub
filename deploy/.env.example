# =============================================================================
# RustDesk CE 部署配置(个人/小团队自托管)
#
# 用法:
#   cp .env.example .env
#   # 把 ★ 标记的几个改一下 → ./scripts/init.sh → docker compose up -d
#
# 所有变量都有默认值(回退在 docker-compose.yml 的 ${VAR:-默认} 里),没改的
# 删行也行。改完不用重 build,docker compose up -d 重启即可生效。
# =============================================================================


# ---------------------------------------------------------------------------
# 1. 对外地址 ★必填
# ---------------------------------------------------------------------------
# 客户端 (RustDesk app) 用来连接的主机名/IP。会被嵌入 rustdesk-api 下发的
# Configuration String,务必填**客户端可达**的地址:
#   - 本机测试      : 127.0.0.1
#   - 局域网其他机器 : 本机内网 IP(如 192.168.1.100)
#   - 公网部署      : 域名或公网 IP
#   - 套 Caddy 反代  : 必须是公网域名
SERVER_HOST=127.0.0.1


# ---------------------------------------------------------------------------
# 2. 镜像来源
# ---------------------------------------------------------------------------
# rustdesk-ce/* 对应本地 `./build.sh` buildx 出的镜像。
# 用 GHCR 上 CI 推的镜像直接拉:
#   IMAGE_NS=ghcr.io/estel-li/rustdesk-ce
#   IMAGE_TAG=edge      # master 最新一次成功 build;或 v0.1.0 这种 tag
#   # 然后 docker compose pull && docker compose up -d
IMAGE_NS=rustdesk-ce
IMAGE_TAG=dev


# ---------------------------------------------------------------------------
# 3. 时区 / 数据目录
# ---------------------------------------------------------------------------
# 影响日志时间戳和 cron(api metrics 上报、token 过期检查都看这个)
TZ=Asia/Shanghai

# 所有持久化数据(server 密钥、api 数据库、postgres 数据卷、Client Builder
# 中间产物)都挂在这个根目录下。生产环境建议改成绝对路径,如 /srv/rustdesk。
DATA_DIR=./data


# ---------------------------------------------------------------------------
# 4. 端口映射(host:container)
# ---------------------------------------------------------------------------
# 这些变量只控制**宿主机**对外的端口,容器内 hbbs/hbbr 永远监听 21115~21121
# (Dockerfile EXPOSE 写死)。compose 映射规则是 `${X_PORT:-默认}:容器内固定端口`。
#
# ⚠️ 重要:hbbs 三个端口必须保持 -1 / 0 / +2 偏移!
#   客户端只配置一个"ID 服务器端口",NAT test 与 WebSocket 是客户端按偏移自己算的:
#     NAT test  = TCP - 1
#     TCP 主    = TCP
#     UDP       = TCP        (同号)
#     WebSocket = TCP + 2
#   想整组挪 → 三个变量一起改;只改其中一个客户端连不上。
#   hbbr 那两个无所谓,客户端从 hbbs 拿"地址字符串"用,任意端口都行。

# hbbs (control plane / ID server):打洞 + ID 注册 + 信令
HBBS_NAT_PORT=21115            # NAT type 检测 (TCP)
HBBS_TCP_PORT=21116            # ID 注册 / 信令主端口 (TCP)
HBBS_UDP_PORT=21116            # 同上端口 (UDP,必须跟 TCP 同号)
HBBS_WS_PORT=21118             # 网页客户端 WebSocket

# hbbr (data plane / relay):打洞失败时的中继兜底
HBBR_TCP_PORT=21117
HBBR_WS_PORT=21119

# rustdesk-api:管理后台 / 网页客户端 / Configuration String 下发
# 启 Caddy profile 后这个会被 caddy 反代到 443,host 端口不再对外。
API_PORT=21114


# ---------------------------------------------------------------------------
# 5. Metrics 监听(CE-M0-3 / M0-4)
# ---------------------------------------------------------------------------
# 三个 metrics 端口 (21120 / 21121 / 21115) 默认**不映射到 host**,内网
# prometheus 通过 docker service name 直接抓。一般不用动。
#
# 想从宿主机直接 curl 测,在 docker-compose.yml 的 ports 段手动加一行映射。
HBBS_METRICS_BIND=0.0.0.0:21120
HBBR_METRICS_BIND=0.0.0.0:21121
API_METRICS_BIND=0.0.0.0:21115


# ---------------------------------------------------------------------------
# 6. RustDesk 公钥 —— init.sh 自动写,别手改 ★
# ---------------------------------------------------------------------------
# hbbs 首次启动会在 data/server/ 下生成 id_ed25519 + id_ed25519.pub 密钥对。
# `./scripts/init.sh` 会把 pub 内容(base64)回写到 .env 里这一行。
# 客户端必须用这个 key 连服务器,不匹配会拒绝。
RUSTDESK_PUB_KEY=


# ===========================================================================
# 以下变量只有启用对应 profile 时才生效,默认 core profile 下完全无作用。
# ===========================================================================


# ---------------------------------------------------------------------------
# 7. Caddy 反代 (profiles/caddy.yml) —— 自动 HTTPS / Let's Encrypt
# ---------------------------------------------------------------------------
# 启用条件:SERVER_HOST 必须是公网域名 + DNS A 记录已指向本机 + 80/443 通畅。
# 用法:docker compose -f docker-compose.yml -f profiles/caddy.yml up -d
ACME_EMAIL=admin@example.com   # Let's Encrypt 续期/吊销通知邮箱


# ---------------------------------------------------------------------------
# 8. PostgreSQL (profiles/postgres.yml) —— 从默认 SQLite 切到 PG
# ---------------------------------------------------------------------------
# 用法:docker compose -f docker-compose.yml -f profiles/postgres.yml up -d
# 切换前先备份 ./data/api/db_v2.sqlite3,手工迁移(rustdesk-api 没自动迁移工具)。
# 密码**不放这里**,放 secrets/postgres_password(0600 权限),
# DSN 也要手写 secrets/postgres_dsn,看 profiles/postgres.yml 末尾的 NOTE。
POSTGRES_USER=rustdesk
POSTGRES_DB=rustdesk


# ---------------------------------------------------------------------------
# 9. Prometheus + Grafana (profiles/metrics.yml)
# ---------------------------------------------------------------------------
# 用法:docker compose -f docker-compose.yml -f profiles/metrics.yml up -d
# 访问:
#   prometheus → http://${SERVER_HOST}:${PROM_PORT}
#   grafana    → http://${SERVER_HOST}:${GRAFANA_PORT}  (首次 admin/admin)
PROM_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin   # ⚠️ 生产务必改,Grafana 首次登录也会强制要求


# ===========================================================================
# 不在这里的东西
# ===========================================================================
#
# ★ rustdesk-api 管理后台密码
#   上游 apimain **不读** ADMIN_USERNAME / ADMIN_PASSWORD 环境变量。
#   首次启动时 users 表为空,自动生成 8 位随机密码,写库 + 打 INFO 日志一次。
#   取密码:./scripts/show-info.sh 或
#          docker compose logs rustdesk-api | grep 'Admin Password Is'
#   进后台后立刻改密 + 开 MFA(CE-M1-2 / M1-5)。
#
# ★ 密钥类全走 secrets/ 文件 + Docker secrets 机制,不要 echo 进 env(会被
#   docker inspect 看见,泄出去):
#     secrets/admin_token          hbbs/hbbr UDS 管理通道 token  (init.sh 生成)
#     secrets/jwt_signing_key      rustdesk-api JWT 签名 key      (CE-M1-3)
#     secrets/mfa_encryption_key   rustdesk-api MFA 密钥加密 key  (CE-M1-1)
#     secrets/postgres_password    PG 用户密码 (启 postgres profile 时手填)
#     secrets/postgres_dsn         GORM DSN  (启 postgres profile 时手填)
#     secrets/rustdesk_key         保留位 (当前未用)
#
#   `./scripts/gen-secrets.sh` 一把生成上面前 3 个;PG 那两个保留给运维手填。
