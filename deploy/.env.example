# =============================================================
# RustDesk CE 部署配置(个人/小团队自托管,基于 docs/ai-tasks/ 的 CE 改造)
#
# 使用方法:
#   1. cp .env.example .env
#   2. 把 SERVER_HOST 改成客户端能访问到的主机名或 IP
#      - 单机本地测试就保持 127.0.0.1
#      - 局域网内其他机器访问,改成本机内网 IP(例如 192.168.1.100)
#      - 公网部署,改成域名或公网 IP
#   3. ./scripts/init.sh
# =============================================================

# 客户端用来连接的主机名/IP。被嵌入到客户端配置串里,务必填可达地址。
SERVER_HOST=127.0.0.1

# 时区
TZ=Asia/Shanghai

# 镜像 tag(本仓 build.sh 默认打 dev;CI 出的话改为 vX.Y.Z)
IMAGE_TAG=dev

# 镜像 namespace 前缀
IMAGE_NS=rustdesk-ce

# ---- 端口映射(host:container)----
# hbbs:打洞 + ID 注册
HBBS_TCP_PORT=21116
HBBS_UDP_PORT=21116
HBBS_NAT_PORT=21115
HBBS_WS_PORT=21118

# hbbr:中继
HBBR_TCP_PORT=21117
HBBR_WS_PORT=21119

# rustdesk-api:Web/API
API_PORT=21114

# ---- CE-M0-3 metrics(默认只在 docker 内网可见,host 不映射)----
HBBS_METRICS_BIND=0.0.0.0:21120
HBBR_METRICS_BIND=0.0.0.0:21121
API_METRICS_BIND=0.0.0.0:21115

# ---- RustDesk 公钥(首次 init.sh 跑完后会自动写入,无需手填)----
# 取自 ./data/server/id_ed25519.pub,base64 编码,客户端用来验证 hbbs 身份
RUSTDESK_PUB_KEY=

# ---- 数据目录(相对 deploy/)----
DATA_DIR=./data

# ---- rustdesk-api 管理后台默认账号(首次启动自动建)----
# 强烈建议第一次登录后改密码并启用 MFA(CE-M1-2/M1-5)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
